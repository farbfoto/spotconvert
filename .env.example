# Spotify Developer App — https://developer.spotify.com/dashboard
# Register the redirect URI below exactly as-is in your Spotify App settings.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://localhost:5173/api/auth/spotify/callback

# Tidal Developer — https://developer.tidal.com
# Register the redirect URI below exactly as-is in your Tidal App settings.
TIDAL_CLIENT_ID=your_tidal_client_id
TIDAL_CLIENT_SECRET=your_tidal_client_secret
TIDAL_REDIRECT_URI=https://localhost:5173/api/auth/tidal/callback

# Session signing key — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# Frontend origin (for CORS) — must match the dev server URL
FRONTEND_URL=https://localhost:5173
