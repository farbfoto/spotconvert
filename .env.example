# Spotify Developer App — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# For local development (Vite dev server proxies /api → backend):
SPOTIFY_REDIRECT_URI=http://localhost:5173/api/auth/spotify/callback

# Tidal Developer — https://developer.tidal.com
TIDAL_CLIENT_ID=your_tidal_client_id
TIDAL_CLIENT_SECRET=your_tidal_client_secret
TIDAL_REDIRECT_URI=http://localhost:5173/api/auth/tidal/callback

# Session signing key — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173
